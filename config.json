{
 "data_dir": "instance",
 # dir for match data shared between bots (fixtures, events); falls back to data_dir
 "shared_dir": "instance",
 "log_file": "instance/betting.log",
 "countries_file": "data/countries.json",
 "token": "",
 "bot_name": <bot-name>,
 "admin_id": <bot-admin-id-int>,
 "admin_name": <admin-username>,
 "group_id": <telegram-group-id-int>,
 "results_url": "<RESULTS URL>",
 "api_token": "<api-football-token>",
 # default or extratime count
 "extra_score_mode": "default",
 # fsnorm or default score alg
 "score_mode": "default",
 # send fixture events
 "events_enabled": false,
 # test mode: post ALL events unfiltered (incl. yellow cards, subs) with a generic label
 "events_test_mode": false,
 # send playoff table
 "playoff_table_enabled": false,
 # updater only: minutes between API refreshes per resource (omit/0 to skip)
 "update_intervals": { "fixtures": 15, "events": 3 },
 "league_id": <api-football-league-id>,
 "season": <api-footbal-season>
}
